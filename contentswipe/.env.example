SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Intercom (for ticket polling + sending replies)
INTERCOM_ACCESS_TOKEN=your-intercom-access-token
INTERCOM_ADMIN_ID=your-intercom-admin-id

# Dust (for AI draft generation — same as PSS/.env)
DUST_API_KEY=your-dust-api-key
DUST_WORKSPACE_ID=your-dust-workspace-id
DUST_AGENT_ID=your-dust-agent-configuration-id
